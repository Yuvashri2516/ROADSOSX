# ============================================================
# RoadSoS X — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Backend ───────────────────────────────────────────────────
DATABASE_URL=sqlite:///./roadsos.db
JWT_SECRET=supersecret_roadsos_key_2026_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Dashboard (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Docker / Production ───────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://your-domain.com/api
# NEXT_PUBLIC_WS_URL=ws://your-domain.com/ws
# DATABASE_URL=postgresql://user:password@db:5432/roadsos_db

# ── AI Vision ─────────────────────────────────────────────────
AI_BACKEND_WS=ws://localhost:8000/ws/telemetry
AI_FPS_LIMIT=15
AI_YOLO_MODEL=yolov8n.pt
